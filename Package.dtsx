          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using System.Net.Mail;
using System.Net;
using System.Data.SqlClient;
using System.Text;
using System.Data.OleDb;
#endregion

namespace ST_d1dcc50421ce46b99a9df5840ebc69a9
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            string subject = "ADP SFTP Files";
            string body = GetFormattedEmailBody();
            sendMail(subject, body);
            Dts.TaskResult = (int)ScriptResults.Success;
        }

        public void sendMail(string Subject, string Body)
        {
            string smtpServer = Dts.Variables["User::SMTPServer"].Value.ToString();
            int smtpPort = (int)Dts.Variables["User::SMTPPort"].Value;
            string smtpUsername = Dts.Variables["User::SMTPUsername"].Value.ToString();
            string smtpPassword = Dts.Variables["User::SMTPPassword"].Value.ToString();
            string emailFrom = Dts.Variables["User::EmailFrom"].Value.ToString();
            string emailTo = Dts.Variables["User::EmailTo"].Value.ToString();
            string emailCC = Dts.Variables["User::EmailCC"].Value.ToString();

            System.Net.ServicePointManager.SecurityProtocol = (SecurityProtocolType)3072;
            string formattedDate = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            MailMessage htmlMessage = new MailMessage();
            SmtpClient mySmtpClient;

            htmlMessage.From = new MailAddress(emailFrom);
            htmlMessage.To.Add(new MailAddress(emailTo));
            htmlMessage.CC.Add(emailCC);
            htmlMessage.Subject = Subject + " @ " + formattedDate;
            htmlMessage.IsBodyHtml = true;
            htmlMessage.Body = Body;

            mySmtpClient = new SmtpClient(smtpServer);
            mySmtpClient.Port = smtpPort;
            mySmtpClient.Credentials = new NetworkCredential(smtpUsername, smtpPassword);
            mySmtpClient.EnableSsl = true;
            mySmtpClient.Send(htmlMessage);

        }

        public string GetFormattedEmailBody()
        {
            StringBuilder emailBody = new StringBuilder();
            emailBody.Append("<html><body><h2>ADP Data Overview</h2>"); //ADP Phone and Email files have been processed successfully and database updated with latest ADP data !
            emailBody.Append("<font size='10px'>The ADP Phone and Email files have been processed successfully, and the database has been updated with the latest ADP data. Below are sample records for testing the ADP data.</font></BR>");
            emailBody.Append("<table border='1' cellpadding='5' cellspacing='0'>");
            emailBody.Append("<tr><th>EIN</th><th>PlanNumber</th><th>SponsorName</th><th>Email</th><th>PhoneNumber</th></tr>");
            
            string query = @"
            SELECT DISTINCT TOP 20 
            e.EIN, 
	        e.PlanNumber,
            e.Name AS SponsorName, 
            j.Email, 
            s.PhoneNumber
        FROM EINsAndPlanNumbers e
        INNER JOIN Sponsors s 
            ON e.EIN = s.EIN
        INNER JOIN solr.LatestFilingIDs l 
            ON e.FilingID = l.FilingID
        INNER JOIN Plans_PlanContacts pp 
            ON e.PlanID = pp.PlanID
        INNER JOIN PlanContacts p 
            ON pp.PlanContactID = p.PlanContactID
        INNER JOIN JDContactsDNC j 
            ON p.EmailAddress = j.Email
        INNER JOIN JDContactsPhoneDNC jp 
            ON s.PhoneNumber = jp.Phone
        INNER JOIN (
            SELECT FilingID FROM Prospector.FilteredFilings
            UNION ALL
            SELECT FilingID FROM GroupInsurance.FilteredFilings
        ) f 
            ON e.FilingID = f.FilingID
        WHERE e.FilingYear >= (
                SELECT End_Year - 1 
                FROM dbo.ImportSettings 
                WHERE Source = 'Prospector'
            )
            AND ISNULL(p.EmailAddress, '') != ''
            AND ISNULL(s.PhoneNumber, '') != ''";

            string connMgrName = "EmailConnection";
            SqlConnection sqlConn = (SqlConnection)Dts.Connections[connMgrName].AcquireConnection(Dts.Transaction);

            try
            {
                using (SqlCommand cmd = new SqlCommand(query, sqlConn))
                {
                    cmd.CommandTimeout = 0;
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            emailBody.Append("<tr>");
                            emailBody.Append("<td>" + reader["EIN"].ToString() + "</td>");
                            emailBody.Append("<td>" + reader["PlanNumber"].ToString() + "</td>");
                            emailBody.Append("<td>" + reader["SponsorName"].ToString() + "</td>");
                            emailBody.Append("<td>" + reader["Email"].ToString() + "</td>");
                            emailBody.Append("<td>" + reader["PhoneNumber"].ToString() + "</td>");
                            emailBody.Append("</tr>");
                        }
                    }
                }
            }
            finally
            {
                Dts.Connections[connMgrName].ReleaseConnection(sqlConn);
            }

            // Database connection string
            //SqlConnection SQLConn = new SqlConnection();
            //SQLConn.ConnectionString = @"Data Source=10.9.57.8;Initial Catalog=Diamond360;User ID=jdauser;Password=jd2007a!;Persist Security Info=False;";

            //SqlCommand testRecordsCmd = new SqlCommand(query, SQLConn);
            //SQLConn.Open();

            //SqlDataReader testRecordsReader = null;
            //testRecordsCmd.CommandTimeout = 0;
            //testRecordsReader = testRecordsCmd.ExecuteReader();

            //if (testRecordsReader.HasRows)
            //{
            //    using (SqlConnection connection = new SqlConnection(SQLConn.ConnectionString))
            //    {
            //        while (testRecordsReader.Read())
            //        {
            //            emailBody.Append("<tr>");
            //            emailBody.Append("<td>" + testRecordsReader["EIN"].ToString() + "</td>");
            //            emailBody.Append("<td>" + testRecordsReader["PlanNumber"].ToString() + "</td>");
            //            emailBody.Append("<td>" + testRecordsReader["SponsorName"].ToString() + "</td>");
            //            emailBody.Append("<td>" + testRecordsReader["Email"].ToString() + "</td>");
            //            emailBody.Append("<td>" + testRecordsReader["PhoneNumber"].ToString() + "</td>");
            //            emailBody.Append("</tr>");
            //        }
            //        testRecordsReader.Close();
            //        connection.Close();
            //    }
            //}

            emailBody.Append("</table>");
            emailBody.Append("</body></html>");
            return emailBody.ToString();
        }

        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };

    }
}]]></ProjectItem>
