          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using System.Net.Mail;
using System.Net;
#endregion

namespace ST_d1dcc50421ce46b99a9df5840ebc69a9
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            sendMail("ADP SFTP Files", "No files were uploaded to the ADP SFTP.");
            Dts.TaskResult = (int)ScriptResults.Success; // Stop
        }

        public void sendMail(string Subject, string Body)
        {
            string smtpServer = Dts.Variables["User::SMTPServer"].Value.ToString();
            int smtpPort = (int)Dts.Variables["User::SMTPPort"].Value;
            string smtpUsername = Dts.Variables["User::SMTPUsername"].Value.ToString();
            string smtpPassword = Dts.Variables["User::SMTPPassword"].Value.ToString();
            string emailFrom = Dts.Variables["User::EmailFrom"].Value.ToString();
            string emailTo = Dts.Variables["User::EmailTo"].Value.ToString();
            string emailCC = Dts.Variables["User::EmailCC"].Value.ToString();

            System.Net.ServicePointManager.SecurityProtocol = (SecurityProtocolType)3072;
            string formattedDate = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            MailMessage htmlMessage = new MailMessage();
            SmtpClient mySmtpClient;

            htmlMessage.From = new MailAddress(emailFrom);
            htmlMessage.To.Add(new MailAddress(emailTo));
            htmlMessage.CC.Add(emailCC);
            htmlMessage.Subject = Subject + " @ " + formattedDate;
            htmlMessage.IsBodyHtml = true;
            htmlMessage.Body = Body;

            mySmtpClient = new SmtpClient(smtpServer);
            mySmtpClient.Port = smtpPort;
            mySmtpClient.Credentials = new NetworkCredential(smtpUsername, smtpPassword);
            mySmtpClient.EnableSsl = true;
            mySmtpClient.Send(htmlMessage);

        }

        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };

    }
}]]></ProjectItem>
